from scapy.all import *

# Build a simple IP packet to a target
ip = IP(dst="192.168.1.1")   # Replace with a test IP

# Build a TCP SYN packet to port 80
tcp = TCP(dport=80, flags="S")

# Combine them
packet = ip/tcp

# Send the packet and wait for a response (timeout 2 seconds)
response = sr1(packet, timeout=2, verbose=0)

if response:
    response.show()
else:
    print("No response")